<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ลงข่าวใหม่ | โรงพยาบาลเถิน</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="bg-white border-bottom py-3 sticky-top">
      <div class="container d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
          <a href="/" class="brand-logo">
            <img src="/favicon.ico" alt="Hospital Logo" style="width: 32px; height: 32px" />
            <span class="brand-text">ประชาสัมพันธ์โรงพยาบาลเถิน</span>
          </a>
        </div>
        <div class="header-actions d-flex gap-2">
          <a href="/" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2 rounded-pill" title="หน้าแรก">
            <i class="bi bi-house-door-fill"></i><span class="d-none d-sm-inline"> หน้าแรก</span>
          </a>
          <a href="/admin/upload" class="btn btn-primary btn-sm d-flex align-items-center gap-2 rounded-pill shadow-sm" title="ลงข่าวใหม่">
            <i class="bi bi-plus-lg"></i><span class="d-none d-sm-inline"> ลงข่าวใหม่</span>
          </a>
          <a href="/admin/logout" class="btn btn-danger btn-sm d-flex align-items-center gap-2 rounded-pill" title="Logout">
            <i class="bi bi-box-arrow-right"></i><span class="d-none d-sm-inline"> Logout</span>
          </a>
        </div>
      </div>
    </header>

    <main class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <h2 class="fw-bold text-dark mb-4">ลงข่าวประชาสัมพันธ์ใหม่</h2>

          <% if (success) { %>
          <div class="alert alert-success d-flex align-items-center border-0 shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div>บันทึกข้อมูลสำเร็จ!</div>
          </div>
          <% } %>

          <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
              <form id="uploadForm" action="/admin/upload" method="POST" enctype="multipart/form-data">
                <div class="row g-3">
                  <div class="col-md-8">
                    <label class="form-label fw-bold">หัวข้อข่าวสาร</label>
                    <input type="text" name="title" class="form-control" placeholder="ระบุชื่อเรื่อง..." required />
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">หมวดหมู่</label>
                    <select name="category" id="category" class="form-select" required>
                      <option value="ข่าวสารประชาสัมพันธ์">ข่าวสารประชาสัมพันธ์</option>
                      <option value="ประชุมอบรม / สัมมนา">ประชุมอบรม / สัมมนา</option>
                      <option value="ประกาศรับสมัครงาน">ประกาศรับสมัครงาน</option>
                      <option value="ข่าวสารความรู้">ข่าวสารความรู้</option>
                    </select>
                  </div>

                  <div class="col-12"><hr class="text-muted opacity-25" /></div>

                  <div class="col-md-6">
                    <label class="form-label fw-bold text-danger"><i class="bi bi-file-earmark-pdf"></i> ไฟล์ PDF (ถ้ามี)</label>
                    <input type="file" name="pdf_file" class="form-control" accept="application/pdf" />
                    <div class="form-text small">รองรับไฟล์ .pdf ขนาดไม่เกิน 20MB</div>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label fw-bold text-success"><i class="bi bi-images"></i> รูปภาพประกอบ</label>
                    <input type="file" name="images" class="form-control" multiple accept="image/*" />
                    <div class="form-text small">เลือกได้หลายภาพ (JPG, PNG)</div>
                  </div>

                  <div class="col-12"><hr class="text-muted opacity-25" /></div>

                  <div class="col-12">
                    <label class="form-label fw-bold text-danger"><i class="bi bi-youtube"></i> Link YouTube (ถ้ามี)</label>
                    <input type="text" name="youtube_link" class="form-control" placeholder="เช่น https://www.youtube.com/watch?v=..." />
                  </div>

                  <div class="col-12"><hr class="text-muted opacity-25" /></div>

                  <div class="col-12">
                    <div class="bg-light p-3 rounded-3 border">
                      <h6 class="fw-bold mb-3 text-secondary">
                        <i class="bi bi-clock"></i> กำหนดช่วงเวลาแสดงผล
                      </h6>
                      <div class="row g-3">
                        <div class="col-md-6">
                          <label class="form-label small text-muted">เริ่มแสดง (Online)</label>
                          <div class="input-group mb-2">
                            <span class="input-group-text bg-white"><i class="bi bi-calendar-event text-primary"></i></span>
                            <input type="datetime-local" name="start_date" id="start_date" class="form-control" required />
                          </div>
                          <div class="d-flex gap-1 flex-wrap">
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="setStartDate('now')"><i class="bi bi-play-fill me-1"></i>เริ่มทันที</button>
                          </div>
                        </div>
                        <div class="col-md-6">
                          <label class="form-label small text-muted">สิ้นสุด (Offline)</label>
                          <div class="input-group mb-2">
                            <span class="input-group-text bg-white"><i class="bi bi-calendar-x text-danger"></i></span>
                            <input type="datetime-local" name="end_date" id="end_date" class="form-control" required />
                          </div>
                          <div class="d-flex gap-1 flex-wrap">
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="addEndDays(3)">+3 วัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="addEndDays(7)">+7 วัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="addEndDays(30)">+30 วัน</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="addEndDays(365)">+1 ปี</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-1 px-2 rounded-pill fs-7" onclick="setEndUnlimited()">ไม่มีกำหนด</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-bold shadow-sm">
                      <i class="bi bi-cloud-upload-fill me-2"></i> ลงประกาศ
                    </button>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function formatDateTimeLocal(date) {
            const tzoffset = date.getTimezoneOffset() * 60000;
            const localISOTime = (new Date(date - tzoffset)).toISOString().slice(0, 16);
            return localISOTime;
        }
        
        function setStartDate(type) {
            const startInput = document.getElementById('start_date');
            if (type === 'now') {
                startInput.value = formatDateTimeLocal(new Date());
            }
        }
        
        function addEndDays(days) {
            const startInput = document.getElementById('start_date');
            const endInput = document.getElementById('end_date');
            const baseDate = startInput.value ? new Date(startInput.value) : new Date();
            baseDate.setDate(baseDate.getDate() + days);
            endInput.value = formatDateTimeLocal(baseDate);
        }
        
        function setEndUnlimited() {
            const endInput = document.getElementById('end_date');
            const farDate = new Date();
            farDate.setFullYear(farDate.getFullYear() + 10); // 10 years later
            endInput.value = formatDateTimeLocal(farDate);
        }

        // Set default start date to now and end date to +30 days on upload page loads
        window.addEventListener('DOMContentLoaded', () => {
            const startInput = document.getElementById('start_date');
            const endInput = document.getElementById('end_date');
            if (startInput && !startInput.value) {
                setStartDate('now');
            }
            if (endInput && !endInput.value) {
                addEndDays(30);
            }
        });
    </script>
  </body>
</html>
